local FakeLagModule = (function()

-- ── [1] EXECUTOR CAPABILITY DETECTION ─────────────────────
local hasHook    = type(hookmetamethod) == "function"
local hasCheck   = type(checkcaller)    == "function"
local hasDrawing = type(Drawing)        == "table"
local hasGC      = type(getgc)          == "function"

-- ── [2] SERVICE ALIASES ────────────────────────────────────
local Players    = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace  = game:GetService("Workspace")
local LP         = Players.LocalPlayer

local rand   = math.random
local max    = math.max
local clamp  = math.clamp
local insert = table.insert
local unpack = table.unpack
local tw     = task.wait
local tspawn = task.spawn
local tick   = tick
local pcall  = pcall

-- ── [3] CONFIGURATION TABLE ────────────────────────────────
-- All FakeLag settings. Mirror these into your main Config table.
local Config = {
    FakeLag = {
        Enabled    = false,
        -- SimPing: Packet Delay
        SimPing    = true,
        PingMs     = 150,
        PingJitter = 30,
        -- Position Jitter
        PosJitter  = false,
        JitterAmt  = 0.08,
        -- Burst Mode
        BurstMode  = false,
        BurstHold  = 0.20,
        BurstFire  = 0.05,
        -- Lag Ghost
        GhostShow  = false,
        GhostTrans = 0.65,
        GhostColor = Color3.fromRGB(120, 180, 255),
    }
}

-- ── [4] STATE VARIABLES ────────────────────────────────────
local FL_Thread       = nil   -- sentinel: true when system is running
local FL_CancelToken  = nil   -- { dead = bool } cancellation token
local FL_QueueActive  = false -- true = Burst Hold phase (do NOT fire)
local FL_JitterThread = nil
local FL_GhostThread  = nil
local FL_GhostModel   = nil

-- ── [5] PACKET QUEUE (Simple Array Queue) ──────────────────
-- Uses head/tail indices. No table.remove(t,1) O(n) shifts.
-- Compact runs amortized O(1) when head > 64.
local PacketQueue = { data = {}, head = 1, tail = 0 }

local function Q_Push(q, pkt)
    q.tail = q.tail + 1
    q.data[q.tail] = pkt
end

local function Q_IsEmpty(q)
    return q.head > q.tail
end

local function Q_Compact(q)
    local newdata, n = {}, 0
    for i = q.head, q.tail do
        if q.data[i] then
            n = n + 1
            newdata[n] = q.data[i]
        end
    end
    q.data = newdata
    q.head = 1
    q.tail = n
end

local function Q_Reset(q)
    q.data = {}
    q.head = 1
    q.tail = 0
end

-- ── [6] FL_QueuePacket ─────────────────────────────────────
-- Called from __namecall hook. Returns true if packet was queued
-- (so hook can return nil and suppress the original FireServer call).
-- NEVER called for InvokeServer — that must pass through immediately.
local function FL_QueuePacket(fn)
    if not Config.FakeLag.Enabled or not Config.FakeLag.SimPing then
        return false
    end
    local jMs    = Config.FakeLag.PingJitter
    local delay  = Config.FakeLag.PingMs + rand(-jMs, jMs)
    local fireAt = tick() + max(0.005, delay / 1000)
    Q_Push(PacketQueue, { fn = fn, fireAt = fireAt })
    return true
end

local FireServerRaw
local UnreliableFireServerRaw
pcall(function()
    local re = Instance.new("RemoteEvent")
    FireServerRaw = re.FireServer
    re:Destroy()
    local ure = Instance.new("UnreliableRemoteEvent")
    UnreliableFireServerRaw = ure.FireServer
    ure:Destroy()
end)

-- ── [7] HOOK __namecall ────────────────────────────────────
-- Only install if executor supports hookmetamethod + checkcaller.
local OldNC
if hasHook and hasCheck then
    OldNC = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()

        -- SimPing: only FireServer, NEVER InvokeServer
        if not checkcaller()
            and Config.FakeLag.Enabled
            and Config.FakeLag.SimPing
            and method == "FireServer"
            and (self:IsA("RemoteEvent") or self:IsA("UnreliableRemoteEvent")) then
            local _self = self
            local _args = {...}
            local _class = _self.ClassName
            local queued = FL_QueuePacket(function()
                if _class == "UnreliableRemoteEvent" and UnreliableFireServerRaw then
                    pcall(UnreliableFireServerRaw, _self, unpack(_args))
                elseif _class == "RemoteEvent" and FireServerRaw then
                    pcall(FireServerRaw, _self, unpack(_args))
                else
                    pcall(function() _self:FireServer(unpack(_args)) end)
                end
            end)
            if queued then return nil end
        end

        return OldNC(self, ...)
    end)
end

-- ── [8] PACKET WORKER THREAD ───────────────────────────────
-- Runs every Heartbeat. Respects FL_QueueActive:
--   true  → Burst Hold phase: do NOT fire anything.
--   false → fire all packets whose fireAt <= now.
-- On token.dead: flush remaining packets then reset queue.
local function StartPacketWorker(token)
    tspawn(function()
        while not token.dead do
            local now = tick()
            local q   = PacketQueue

            -- Amortized compact
            if q.head > 256 then Q_Compact(q) end
            if Q_IsEmpty(q) then Q_Reset(q) end

            -- [BUG-1 FIX] Only fire when NOT in Burst Hold
            if not FL_QueueActive then
                local newHead = q.tail + 1
                for i = q.head, q.tail do
                    if token.dead then break end
                    local pkt = q.data[i]
                    if pkt then
                        -- [BURST FIX]: If BurstMode is ON, flush everything instantly when Hold is released!
                        if Config.FakeLag.BurstMode or now >= pkt.fireAt then
                            pcall(pkt.fn)
                            q.data[i] = nil
                        else
                            if i < newHead then newHead = i end
                        end
                    end
                end
                q.head = newHead
            end

            RunService.Heartbeat:Wait()
        end

        -- Flush remaining packets on stop (prevent data loss)
        local q = PacketQueue
        for i = q.head, q.tail do
            local pkt = q.data[i]
            if pkt then pcall(pkt.fn) end
        end
        Q_Reset(q)
    end)
end

-- ── [9] BURST CYCLE THREAD ─────────────────────────────────
-- Alternates FL_QueueActive:
--   Hold phase (true):  packets accumulate → creates spike
--   Fire phase (false): worker fires all queued packets at once
local function StartBurstCycle(token)
    tspawn(function()
        while not token.dead and Config.FakeLag.BurstMode do
            FL_QueueActive = true           -- Accumulate
            local elapsedHold = 0
            while elapsedHold < Config.FakeLag.BurstHold and not token.dead do
                elapsedHold = elapsedHold + RunService.Heartbeat:Wait()
            end
            if token.dead then break end
            FL_QueueActive = false          -- Release burst
            local elapsedFire = 0
            while elapsedFire < Config.FakeLag.BurstFire and not token.dead do
                elapsedFire = elapsedFire + RunService.Heartbeat:Wait()
            end
        end
        FL_QueueActive = false
    end)
end

-- ── [10] POSITION JITTER THREAD (CFrame Network Desync) ───────
-- [REAL FAKELAG FIX]: Adding velocity noise does NOT make you lag to others.
-- We must use a RenderStepped/Heartbeat CFrame Swap:
-- 1. Heartbeat (before network rep): Override hrp.CFrame to the Lagged CFrame.
-- 2. RenderStepped (before camera/physics): Restore the Real CFrame so the client is 100% smooth.
local function StartJitter(token)
    if FL_JitterThread then return end
    FL_JitterThread = tspawn(function()
        local rsConn, hbConn
        local realCF, realVel
        local lagCF, lagVel
        local lastLagUpdate = 0
        
        rsConn = RunService.RenderStepped:Connect(function()
            if token.dead or not Config.FakeLag.PosJitter then return end
            local lpChar = LP.Character
            local hrp = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
            if hrp and realCF then
                -- Restore real position for local camera and physics simulation
                hrp.CFrame = realCF
                if realVel then hrp.AssemblyLinearVelocity = realVel end
            end
        end)
        
        hbConn = RunService.Heartbeat:Connect(function()
            if token.dead or not Config.FakeLag.PosJitter then return end
            local lpChar = LP.Character
            local hrp = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Heartbeat fires AFTER physics simulation. Save newly simulated real position.
                realCF = hrp.CFrame
                realVel = hrp.AssemblyLinearVelocity
                
                local now = tick()
                local updateInterval = max(0.05, Config.FakeLag.JitterAmt)
                
                -- If Burst Hold is active, freeze the lagCF entirely!
                if Config.FakeLag.BurstMode and FL_QueueActive then
                    -- hold lagCF
                else
                    if not lagCF or (now - lastLagUpdate) >= updateInterval then
                        lagCF = realCF
                        lagVel = realVel
                        lastLagUpdate = now
                    end
                end
                
                -- Override CFrame to the Lagged CFrame for network replication!
                if lagCF then
                    hrp.CFrame = lagCF
                    local currentVel = hrp.AssemblyLinearVelocity
                    hrp.AssemblyLinearVelocity = Vector3.new(0, currentVel.Y, 0)
                end
            end
        end)
        
        while not token.dead and Config.FakeLag.PosJitter do
            tw(0.1)
        end
        
        -- Cleanup
        rsConn:Disconnect()
        hbConn:Disconnect()
        local lpChar = LP.Character
        local hrp = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
        if hrp and realCF then
            hrp.CFrame = realCF
            if realVel then hrp.AssemblyLinearVelocity = realVel end
        end
        FL_JitterThread = nil
    end)
end

-- ── [11] LAG GHOST ─────────────────────────────────────────
-- Creates a semi-transparent anchored clone of the local character
-- positioned at its delayed CFrame (simulating what the server sees).

local function DestroyGhost()
    if FL_GhostModel then
        pcall(function() FL_GhostModel:Destroy() end)
        FL_GhostModel = nil
    end
end

-- [FIX-4] Only clone direct BasePart children (skip Accessory/Hat/Tool)
-- This prevents ~60% extra parts from accessories from causing lag.
local function CreateGhost(sourceChar)
    DestroyGhost()
    if not sourceChar then return nil end

    local SKIP = { Accessory=true, Hat=true, Tool=true,
                   Script=true, LocalScript=true, ModuleScript=true }

    local ok, ghost = pcall(function()
        local g    = Instance.new("Model")
        g.Name     = "_FL_Ghost"
        local trans = Config.FakeLag.GhostTrans
        local color = Config.FakeLag.GhostColor
        local MAT   = Enum.Material.ForceField

        for _, part in ipairs(sourceChar:GetChildren()) do
            if part:IsA("BasePart") and not SKIP[part.ClassName] then
                local clone = Instance.new("Part")
                clone.Name         = part.Name
                clone.Size         = part.Size
                clone.CFrame       = part.CFrame
                clone.Anchored     = true
                clone.CanCollide   = false
                clone.CanTouch     = false
                clone.CanQuery     = false
                clone.CastShadow   = false
                clone.Material     = MAT
                clone.Color        = color
                -- HRP itself fully transparent (anchor only)
                clone.Transparency = (part.Name == "HumanoidRootPart") and 1 or trans

                -- Copy SpecialMesh to preserve body shape
                local mesh = part:FindFirstChildOfClass("SpecialMesh")
                          or part:FindFirstChildOfClass("DataModelMesh")
                if mesh then mesh:Clone().Parent = clone end

                clone.Parent = g
            end
        end

        -- Set PrimaryPart for world-transform math
        local hrpClone = g:FindFirstChild("HumanoidRootPart")
        if hrpClone then g.PrimaryPart = hrpClone end

        g.Parent = Workspace
        return g
    end)

    if ok and ghost then
        FL_GhostModel = ghost
        return ghost
    end
    return nil
end

-- [FIX-5] World-space delta transform:
--   delta = delayCF * srcHRP.CFrame:Inverse()
--   Apply: ghostPart.CFrame = delta * srcPart.CFrame
-- This is correct for ALL rotation states (avoids relative offset math errors).
local function UpdateGhostCFrame(sourceChar, ghost, delayCF)
    if not sourceChar or not ghost then return end
    local srcHRP = sourceChar:FindFirstChild("HumanoidRootPart")
    if not srcHRP then return end

    local delta = delayCF * srcHRP.CFrame:Inverse()

    for _, gPart in ipairs(ghost:GetChildren()) do
        if gPart:IsA("BasePart") then
            local srcPart = sourceChar:FindFirstChild(gPart.Name)
            if srcPart and srcPart:IsA("BasePart") then
                pcall(function()
                    gPart.CFrame = delta * srcPart.CFrame
                end)
            end
        end
    end
end

-- Ghost thread: records HRP CFrame history (3 sec buffer),
-- lerps to the delayed position each Heartbeat.
local function StartGhostThread(token)
    if FL_GhostThread then return end
    FL_GhostThread = tspawn(function()
        local history   = {}       -- { { t=tick(), cf=CFrame }, ... }
        local MAX_HIST  = 3.0      -- seconds of history to keep
        local ghost     = nil
        local rebuildCD = 0
        local charAddedConn = LP.CharacterAdded:Connect(function()
            DestroyGhost()
            ghost = nil
            rebuildCD = 0
        end)

        while not token.dead and Config.FakeLag.Enabled do
            local now    = tick()
            local lpChar = LP.Character
            local hrp    = lpChar and lpChar:FindFirstChild("HumanoidRootPart")

            if hrp and Config.FakeLag.GhostShow then
                -- Record current CFrame
                insert(history, { t = now, cf = hrp.CFrame })

                -- Prune entries older than MAX_HIST seconds
                local cutoff = now - MAX_HIST
                while #history > 2 and history[1].t < cutoff do
                    table.remove(history, 1)
                end

                -- (Re)build ghost model if missing
                if (not ghost or not ghost.Parent) and now > rebuildCD then
                    ghost = CreateGhost(lpChar)
                    rebuildCD = now + 2.0
                end

                -- Compute playback time = now minus simulated ping
                local delayS   = Config.FakeLag.PingMs / 1000
                local playTime = now - delayS

                -- Binary-ish search for surrounding samples
                local before, after = nil, nil
                for i = #history, 1, -1 do
                    if history[i].t <= playTime then
                        before = history[i]
                        if i < #history then after = history[i + 1] end
                        break
                    end
                end

                if before and ghost then
                    local delayCF
                    if after then
                        local span  = after.t - before.t
                        local alpha = (span > 0.001)
                            and clamp((playTime - before.t) / span, 0, 1) or 0
                        delayCF = before.cf:Lerp(after.cf, alpha)
                    else
                        delayCF = before.cf
                    end
                    UpdateGhostCFrame(lpChar, ghost, delayCF)
                end

                -- Live-update transparency & color (responds to UI changes)
                if ghost then
                    local trans = Config.FakeLag.GhostTrans
                    local color = Config.FakeLag.GhostColor
                    for _, gPart in ipairs(ghost:GetChildren()) do
                        if gPart:IsA("BasePart") and gPart.Name ~= "HumanoidRootPart" then
                            if gPart.Transparency ~= trans then gPart.Transparency = trans end
                            if gPart.Color ~= color        then gPart.Color = color end
                        end
                    end
                end

            else
                -- GhostShow disabled or no character → clean up
                if ghost and ghost.Parent then
                    DestroyGhost()
                    ghost = nil
                end
                history = {}
            end

            RunService.Heartbeat:Wait()
        end

        -- Cleanup on thread exit
        charAddedConn:Disconnect()
        DestroyGhost()
        ghost   = nil
        history = nil
        FL_GhostThread = nil
    end)
end

-- ── [12] START / STOP LIFECYCLE ────────────────────────────
local function StartFakeLag()
    if FL_Thread then return end  -- already running

    FL_CancelToken = { dead = false }
    Q_Reset(PacketQueue)
    FL_QueueActive = false

    -- Packet worker always runs (needed even without BurstMode)
    StartPacketWorker(FL_CancelToken)

    -- Conditional threads based on config
    if Config.FakeLag.BurstMode then StartBurstCycle(FL_CancelToken) end
    if Config.FakeLag.PosJitter then StartJitter(FL_CancelToken)     end

    -- Ghost thread always starts; it self-gates on GhostShow flag
    StartGhostThread(FL_CancelToken)

    FL_Thread = true
end

local function StopFakeLag()
    Config.FakeLag.Enabled = false
    FL_QueueActive = false

    if FL_CancelToken then
        FL_CancelToken.dead = true  -- All threads detect this and exit
        FL_CancelToken = nil
    end

    DestroyGhost()

    FL_Thread       = nil
    FL_JitterThread = nil
    FL_GhostThread  = nil
end

-- ── [13] PUBLIC API ────────────────────────────────────────
return {
    Config       = Config,
    Start        = StartFakeLag,
    Stop         = StopFakeLag,
    DestroyGhost = DestroyGhost,
    CreateGhost  = CreateGhost,
    QueuePacket  = FL_QueuePacket,
    GetQueue     = function() return PacketQueue end,
    FlushQueue   = function()
        local q = PacketQueue
        local n = 0
        FL_QueueActive = false
        for i = q.head, q.tail do
            local pkt = q.data[i]
            if pkt then pcall(pkt.fn); n = n + 1 end
        end
        Q_Reset(q)
        return n
    end,
    QueueSize = function()
        local q, n = PacketQueue, 0
        for i = q.head, q.tail do
            if q.data[i] then n = n + 1 end
        end
        return n
    end,
    IsRunning = function() return FL_Thread == true end,
    -- Executor capability flags (read-only for UI display)
    Caps = {
        hookmetamethod = hasHook,
        checkcaller    = hasCheck,
        Drawing        = hasDrawing,
        getgc          = hasGC,
    },
}

end)()

